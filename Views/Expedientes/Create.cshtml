@model ColegioSanJose.Models.Expediente
@{
    ViewData["Title"] = "Nuevo Expediente";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Nuevo Expediente</h1>
    <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
        <i class="fas fa-arrow-left fa-sm"></i> Volver
    </a>
</div>

<div class="card shadow mb-4 border-left-warning">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-warning">Datos del Expediente</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group">
                <label asp-for="AlumnoId" class="font-weight-bold"></label>
                <select asp-for="AlumnoId" class="form-control" asp-items="ViewBag.AlumnoId">
                    <option value="">-- Seleccione un Alumno --</option>
                </select>
                <span asp-validation-for="AlumnoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MateriaId" class="font-weight-bold"></label>
                <select asp-for="MateriaId" class="form-control" asp-items="ViewBag.MateriaId">
                    <option value="">-- Seleccione una Materia --</option>
                </select>
                <span asp-validation-for="MateriaId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NotaFinal" class="font-weight-bold"></label>
                <input asp-for="NotaFinal" class="form-control" placeholder="Ingrese la nota (0-10)" />
                <span asp-validation-for="NotaFinal" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Observaciones" class="font-weight-bold"></label>
                <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Ingrese observaciones (opcional)"></textarea>
                <span asp-validation-for="Observaciones" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="fas fa-save"></i> Guardar
            </button>
            <a asp-action="Index" class="btn btn-danger">
                <i class="fas fa-times"></i> Cancelar
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}