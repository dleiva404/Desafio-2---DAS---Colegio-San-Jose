@model IEnumerable<ColegioSanJose.Models.Expediente>
@{
    ViewData["Title"] = "Expedientes";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Gestión de Expedientes</h1>
    <a asp-action="Create" class="btn btn-warning btn-sm shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Nuevo Expediente
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-warning">Lista de Expedientes</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="thead-dark">
                    <tr>
                        <th>Alumno</th>
                        <th>Materia</th>
                        <th>@Html.DisplayNameFor(model => model.NotaFinal)</th>
                        <th>@Html.DisplayNameFor(model => model.Observaciones)</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Alumno.Nombres @item.Alumno.Apellidos</td>
                            <td>@Html.DisplayFor(modelItem => item.Materia.NombreMateria)</td>
                            <td>@Html.DisplayFor(modelItem => item.NotaFinal)</td>
                            <td>@Html.DisplayFor(modelItem => item.Observaciones)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.ExpedienteId" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Details" asp-route-id="@item.ExpedienteId" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i> Detalles
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ExpedienteId" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>