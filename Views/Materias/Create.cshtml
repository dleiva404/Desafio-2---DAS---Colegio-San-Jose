@model ColegioSanJose.Models.Materia
@{
    ViewData["Title"] = "Nueva Materia";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Nueva Materia</h1>
    <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
        <i class="fas fa-arrow-left fa-sm"></i> Volver
    </a>
</div>

<div class="card shadow mb-4 border-left-success">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-success">Datos de la Materia</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group">
                <label asp-for="NombreMateria" class="font-weight-bold"></label>
                <input asp-for="NombreMateria" class="form-control" placeholder="Ingrese el nombre de la materia" />
                <span asp-validation-for="NombreMateria" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Docente" class="font-weight-bold"></label>
                <input asp-for="Docente" class="form-control" placeholder="Ingrese el nombre del docente" />
                <span asp-validation-for="Docente" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="fas fa-save"></i> Guardar
            </button>
            <a asp-action="Index" class="btn btn-danger">
                <i class="fas fa-times"></i> Cancelar
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}