@model IEnumerable<ColegioSanJose.Models.Materia>
@{
    ViewData["Title"] = "Materias";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Gestión de Materias</h1>
    <a asp-action="Create" class="btn btn-success btn-sm shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Nueva Materia
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-success">Lista de Materias</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                <thead class="thead-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.NombreMateria)</th>
                        <th>@Html.DisplayNameFor(model => model.Docente)</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.NombreMateria)</td>
                            <td>@Html.DisplayFor(modelItem => item.Docente)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.MateriaId" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <a asp-action="Details" asp-route-id="@item.MateriaId" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i> Detalles
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.MateriaId" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>