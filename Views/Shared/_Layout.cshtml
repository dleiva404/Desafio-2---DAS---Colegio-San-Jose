<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Colegio San José</title>

    <!-- Custom fonts-->
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet" />

    <!-- Custom styles-->
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet" />
    <style>
        #content-wrapper {
            overflow-y: auto;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        #content {
            flex: 1;
        }

            #content .topbar {
                position: sticky;
                top: 0;
                z-index: 1030;
            }
    </style>
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
            <a class="sidebar-brand d-flex align-items-center justify-content-center" asp-controller="Home" asp-action="Index">
                <div class="sidebar-brand-text mx-3">Colegio<br>San José</div>
            </a>

            <hr class="sidebar-divider my-0" />

            <li class="nav-item active">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-fw fa-home"></i>
                    <span>Inicio</span>
                </a>
            </li>

            <hr class="sidebar-divider" />
            <div class="sidebar-heading">Gestión</div>

            <li class="nav-item">
                <a class="nav-link" asp-controller="Alumnos" asp-action="Index">
                    <i class="fas fa-fw fa-user-graduate"></i>
                    <span>Alumnos</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-controller="Materias" asp-action="Index">
                    <i class="fas fa-fw fa-book"></i>
                    <span>Materias</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-controller="Expedientes" asp-action="Index">
                    <i class="fas fa-fw fa-file-alt"></i>
                    <span>Expedientes</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Expedientes" asp-action="Promedios">
                    <i class="fas fa-fw fa-chart-bar"></i>
                    <span>Promedios</span>
                </a>
            </li>

            <hr class="sidebar-divider d-none d-md-block" />
        </ul>
        <!-- End of Sidebar -->
        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>
                    <ul class="navbar-nav ml-auto">
                        <li class="nav-item">
                            <span class="nav-link">Sistema de Gestión Académica</span>
                        </li>
                    </ul>
                </nav>
                <!-- End of Topbar -->
                <!-- Begin Page Content -->
                <div class="container-fluid">
                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i> @TempData["Exito"]
                            <button type="button" class="close" data-dismiss="alert">
                                <span>&times;</span>
                            </button>
                        </div>
                    }
                    @RenderBody()
                </div>
                <!-- End of Page Content -->

            </div>
            <!-- End of Main Content -->
            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>© 2026 Colegio San José - Sistema de Gestión Académica</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->
    <!-- Bootstrap core JavaScript-->
    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript-->
    <script src="~/vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages-->
    <script src="~/js/sb-admin-2.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <button id="btnTop" onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            style="display:none; position:fixed; bottom:30px; right:30px; z-index:9999;
           width:45px; height:45px; border-radius:50%; border:none;
           background-color:#4e73df; color:white; font-size:18px;
           box-shadow: 0 4px 8px rgba(0,0,0,0.2); cursor:pointer;">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script>
        var btnTop = document.getElementById("btnTop");
        var contentWrapper = document.getElementById("content-wrapper");

        contentWrapper.addEventListener("scroll", function() {
            if (contentWrapper.scrollTop > 300) {
                btnTop.style.display = "block";
            } else {
                btnTop.style.display = "none";
            }
        });

        document.getElementById("btnTop").addEventListener("click", function() {
            contentWrapper.scrollTo({top: 0, behavior: 'smooth'});
        });
    </script>
</body>
</html>